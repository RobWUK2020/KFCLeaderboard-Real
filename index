                            <p>Front Counter</p>
                        </div>
                        <div class="metric-score">14.2%</div>
                    </div>
                    
                    <div class="rank-card rank-2">
                        <div class="rank-number">2</div>
                        <div class="team-member">
                            <h4>Patrick Anderson</h4>
                            <p>Drive-Thru Window</p>
                        </div>
                        <div class="metric-score">12.5%</div>
                    </div>

                    <div class="rank-card rank-3">
                        <div class="rank-number">3</div>
                        <div class="team-member">
                            <h4>David Taylor</h4>
                            <p>Front Counter</p>
                        </div>
                        <div class="metric-score">11.0%</div>
                    </div>

                    <div class="rank-card">
                        <div class="rank-number">4</div>
                        <div class="team-member">
                            <h4>Emma White</h4>
                            <p>Drive-Thru Window</p>
                        </div>
                        <div class="metric-score">9.5%</div>
                    </div>

                    <div class="rank-card">
                        <div class="rank-number">5</div>
                        <div class="team-member">
                            <h4>James Lewis</h4>
                            <p>Front Counter</p>
                        </div>
                        <div class="metric-score">8.8%</div>
                    </div>
                </div>
            </div>

            <div id="tab-volume" class="tab-content">
                <h2 class="section-title">Total Promo Volume</h2>
                <div class="leaderboard-list">
                    <div class="rank-card rank-1">
                        <div class="rank-number">1</div>
                        <div class="team-member">
                            <h4>Sarah Mitchell</h4>
                            <p>Front Counter</p>
                        </div>
                        <div class="metric-score">48</div>
                    </div>
                    
                    <div class="rank-card rank-2">
                        <div class="rank-number">2</div>
                        <div class="team-member">
                            <h4>Patrick Anderson</h4>
                            <p>Drive-Thru Window</p>
                        </div>
                        <div class="metric-score">43</div>
                    </div>

                    <div class="rank-card rank-3">
                        <div class="rank-number">3</div>
                        <div class="team-member">
                            <h4>James Lewis</h4>
                            <p>Front Counter</p>
                        </div>
                        <div class="metric-score">38</div>
                    </div>

                    <div class="rank-card">
                        <div class="rank-number">4</div>
                        <div class="team-member">
                            <h4>Emma White</h4>
                            <p>Drive-Thru Window</p>
                        </div>
                        <div class="metric-score">31</div>
                    </div>

                    <div class="rank-card">
                        <div class="rank-number">5</div>
                        <div class="team-member">
                            <h4>David Taylor</h4>
                            <p>Front Counter</p>
                        </div>
                        <div class="metric-score">27</div>
                    </div>
                </div>
            </div>

            <div id="tab-shift" class="tab-content">
                <h2 class="section-title">Day vs Night Shift</h2>
                <div class="vs-container">
                    
                    <div class="shift-card">
                        <div class="shift-name">Day Shift</div>
                        <div class="shift-alias">"The Hawkins Openers"</div>
                        <div class="shift-score">152</div>
                    </div>

                    <div class="vs-divider">VS</div>

                    <div class="shift-card winner">
                        <div class="shift-name">Night Shift</div>
                        <div class="shift-alias">"The Upside Down Closers"</div>
                        <div class="shift-score">185</div>
                    </div>

                </div>
            </div>
        </main>

        <div class="prize-banner">
            <h3>🏆 Weekly Prize 🏆</h3>
            <p>1st Place wins a £20 Amazon Voucher + First pick of next week's shifts!</p>
        </div>

    </div>

    <script>
        function switchTab(tabId) {
            // Hide all tab content
            const contents = document.querySelectorAll('.tab-content');
            contents.forEach(content => {
                content.classList.remove('active');
            });

            // Remove active state from all buttons
            const buttons = document.querySelectorAll('.tab-btn');
            buttons.forEach(button => {
                button.classList.remove('active');
            });

            // Show selected tab content
            document.getElementById(tabId).classList.add('active');

            // Add active state to clicked button
            event.currentTarget.classList.add('active');
        }
    </script>
</body>
</html>
